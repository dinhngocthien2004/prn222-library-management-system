@using BusinessObjects.Entities
@model Book

<h2>Thêm sách</h2>

<form method="post">
    <div class="mb-3">
        <label>Tên sách</label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Số lượt mượn</label>
        <input asp-for="BorrowCount" class="form-control" />
    </div>
    <button class="btn btn-success">Thêm</button>
</form>