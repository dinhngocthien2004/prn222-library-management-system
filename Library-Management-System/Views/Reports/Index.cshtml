@using BusinessObjects.Entities
@model List<Book>

<h2>📚 Quản lý sách</h2>

<a asp-action="Create" class="btn btn-success mb-3">+ Thêm sách</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>#</th>
            <th>Tên sách</th>
            <th>Số lượt mượn</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @{
            int i = 1;
        }
        @foreach (var item in Model)
        {
            <tr>
                <td>@i</td>
                <td>@item.Title</td>
                <td>@item.BorrowCount</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookId" class="btn btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.BookId" class="btn btn-danger">Xóa</a>
                </td>
            </tr>
            i++;
        }
    </tbody>
</table>