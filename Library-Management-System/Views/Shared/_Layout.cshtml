﻿
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Library</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <h4 class="text-center text-white mb-4">📚 Library</h4>

            <ul class="nav flex-column">

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        🏠 Dashboard
                    </a>
                </li>


                <!-- BOOKS -->
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#bookMenu">
                        📚 Quản lý sách
                    </a>

                    <div class="collapse" id="bookMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Books" asp-action="Index">
                                    Danh sách sách
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Books" asp-action="Create">
                                    Thêm sách
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Categories" asp-action="Index">
                                    Thể loại
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Publishers" asp-action="Index">
                                    Nhà xuất bản
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>


                <!-- READERS -->
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#readerMenu">
                        👤 Độc giả
                    </a>

                    <div class="collapse" id="readerMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Readers" asp-action="Index">
                                    Danh sách độc giả
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Cards" asp-action="Index">
                                    Thẻ thư viện
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>


                <!-- LOANS -->
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#loanMenu">
                        🔄 Mượn / Trả
                    </a>

                    <div class="collapse" id="loanMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Loans" asp-action="Index">
                                    Danh sách mượn và trả
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Loans" asp-action="Create">
                                    Tạo phiếu mượn
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Returns" asp-action="Index">
                                    Trả sách
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Loans" asp-action="History">
                                    Lịch sử mượn
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>


                <!-- REPORT -->
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#reportMenu">
                        📊 Thống kê
                    </a>

                    <div class="collapse" id="reportMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Reports" asp-action="PopularBooks">
                                    Sách mượn nhiều
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Reports" asp-action="Overdue">
                                    Quá hạn
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Reports" asp-action="Index">
                                    Báo cáo
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>


                <!-- ADMIN -->
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#adminMenu">
                        ⚙️ Quản trị
                    </a>

                    <div class="collapse" id="adminMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Users" asp-action="Index">
                                    Người dùng
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Roles" asp-action="Index">
                                    Phân quyền
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>

            </ul>

        </div>


        <!-- MAIN CONTENT -->
        <div class="main-content flex-grow-1">

            <div class="container-fluid p-4">
                @RenderBody()
            </div>

        </div>

    </div>


    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    @RenderSection("Scripts", required: false)

</body>
</html>