<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Library</title>

    ```
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            min-height: 100vh;
            background: #1f2937;
            padding: 20px;
        }

            .sidebar h4 {
                border-bottom: 1px solid #374151;
                padding-bottom: 10px;
            }

            /* khoảng cách menu */
            .sidebar .nav-item {
                margin-bottom: 10px;
            }

            /* khung menu */
            .sidebar .nav-link {
                color: #cbd5e1;
                padding: 12px 14px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-radius: 8px;
                background: rgba(255,255,255,0.03);
                transition: 0.2s;
            }

                .sidebar .nav-link:hover {
                    background: #374151;
                    color: white;
                }

        /* submenu */
        .submenu {
            list-style: none;
            padding-left: 12px;
            margin-top: 8px;
        }

            .submenu li {
                margin: 6px 0;
            }

                .submenu li a {
                    color: #9ca3af;
                    display: block;
                    padding: 8px 12px;
                    border-radius: 6px;
                    text-decoration: none;
                    background: rgba(255,255,255,0.03);
                    margin-bottom: 6px;
                    transition: 0.2s;
                }

                    .submenu li a:hover {
                        background: #374151;
                        color: white;
                    }

        /* mũi tên */
        .arrow {
            font-size: 12px;
            opacity: 0.7;
            transition: transform 0.3s ease;
        }

        /* xoay mũi tên khi mở */
        .nav-link[aria-expanded="true"] .arrow {
            transform: rotate(180deg);
        }

        .main-content {
            background: #f5f7fb;
            min-height: 100vh;
        }

    </style>
    ```

</head>

<body>

    <div class="d-flex">

        ```
        <!-- SIDEBAR -->
        <div class="sidebar">

            <h4 class="text-center text-white mb-4">📚 Library</h4>

            <ul class="nav flex-column">

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <span>🏠 Dashboard</span>
                    </a>
                </li>


                <!-- BOOKS -->
                <li class="nav-item">
                    <a class="nav-link collapsed" data-bs-toggle="collapse" href="#bookMenu">
                        <span>📚 Quản lý sách</span>
                        <span class="arrow">▼</span>
                    </a>

                    <div class="collapse" id="bookMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Books" asp-action="Index">
                                    Danh sách sách
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Books" asp-action="Create">
                                    Thêm sách
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Categories" asp-action="Index">
                                    Thể loại
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Publishers" asp-action="Index">
                                    Nhà xuất bản
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>


                <!-- READERS -->
                <li class="nav-item">
                    <a class="nav-link collapsed" data-bs-toggle="collapse" href="#readerMenu">
                        <span>👤 Độc giả</span>
                        <span class="arrow">▼</span>
                    </a>

                    <div class="collapse" id="readerMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Readers" asp-action="Index">
                                    Danh sách độc giả
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Cards" asp-action="Index">
                                    Thẻ thư viện
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>


                <!-- LOANS -->
                <li class="nav-item">
                    <a class="nav-link collapsed" data-bs-toggle="collapse" href="#loanMenu">
                        <span>🔄 Mượn / Trả</span>
                        <span class="arrow">▼</span>
                    </a>

                    <div class="collapse" id="loanMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Loans" asp-action="Index">
                                    Danh sách mượn và trả
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Loans" asp-action="Create">
                                    Tạo phiếu mượn
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Returns" asp-action="Index">
                                    Trả sách
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Loans" asp-action="History">
                                    Lịch sử mượn
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>


                <!-- REPORT -->
                <li class="nav-item">
                    <a class="nav-link collapsed" data-bs-toggle="collapse" href="#reportMenu">
                        <span>📊 Thống kê</span>
                        <span class="arrow">▼</span>
                    </a>

                    <div class="collapse" id="reportMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Reports" asp-action="PopularBooks">
                                    Sách mượn nhiều
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Reports" asp-action="Overdue">
                                    Quá hạn
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Reports" asp-action="Index">
                                    Báo cáo
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>


                <!-- ADMIN -->
                <li class="nav-item">
                    <a class="nav-link collapsed" data-bs-toggle="collapse" href="#adminMenu">
                        <span>⚙️ Quản trị</span>
                        <span class="arrow">▼</span>
                    </a>

                    <div class="collapse" id="adminMenu">
                        <ul class="submenu">

                            <li>
                                <a asp-controller="Users" asp-action="Index">
                                    Người dùng
                                </a>
                            </li>

                            <li>
                                <a asp-controller="Roles" asp-action="Index">
                                    Phân quyền
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>

            </ul>

        </div>


        <!-- MAIN CONTENT -->
        <div class="main-content flex-grow-1">

            <div class="container-fluid p-4">
                @RenderBody()
            </div>

        </div>
        ```

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    @RenderSection("Scripts", required: false)

</body>
</html>
