@model IEnumerable<string>

@{
    ViewData["Title"] = "Danh sách Tác giả";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">📚 Danh sách Tác giả</h3>
        </div>

        <div class="card-body">

            <table class="table table-hover table-striped align-middle">

                <thead class="table-dark text-center">
                    <tr>
                        <th style="width:70%; border-right:2px solid #dee2e6;">
                            Nhà Xuất Bản / Tác Giả
                        </th>
                        <th style="width:30%">Tác Phẩm</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var publisher in Model)
                    {
                        <tr>
                            <td class="text-center" style="border-right:2px solid #dee2e6;">
                                @publisher
                            </td>

                            <td class="text-center">
                                <a asp-action="BooksByPublisher"
                                   asp-route-name="@publisher"
                                   class="btn btn-primary btn-sm px-4">
                                    Xem tác phẩm
                                </a>
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
