@model IEnumerable<BusinessObjects.Entities.Book>

@{
    ViewData["Title"] = "Books By Publisher";
}

<div class="container mt-4">

    <div class="card shadow-lg">

        <div class="card-header bg-primary text-white text-center">
            <h3 class="mb-0">📚 Books By Publisher</h3>
        </div>

        <div class="text-center mt-3">
            <a asp-action="Index" class="btn btn-secondary">
                ← Back to Publishers
            </a>
        </div>

        <div class="card-body">

            <table class="table table-striped table-hover table-bordered text-center align-middle">

                <thead class="table-dark">
                    <tr>
                        <th style="width:20%">Book ID</th>
                        <th style="width:50%">Book Title</th>
                        <th style="width:30%">Publisher</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.BookId</td>
                            <td class="text-center">@item.Title</td>
                            <td>@item.Publisher</td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>

    </div>

</div>
