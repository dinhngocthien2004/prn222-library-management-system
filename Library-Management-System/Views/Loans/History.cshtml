@model List<BusinessObjects.Entities.Loan>

@{
    ViewData["Title"] = "Danh Sách Người Dùng";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">👥 Danh Sách Người Dùng</h4>
        </div>

        <div class="card-body">

            <p class="text-muted">
                Danh sách người dùng và lịch sử mượn sách trong hệ thống
            </p>

            <table class="table table-hover table-bordered align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>Người dùng</th>
                        <th>Sách đã mượn</th>
                        <th>Ngày mượn</th>
                        <th>Hạn trả</th>
                        <th>Ngày trả</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    @item.ReaderName
                                </td>

                                <td>
                                    @item.BookTitle
                                </td>

                                <td>
                                    @item.LoanDate?.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    @item.DueDate.ToString("dd/MM/yyyy")
                                </td>

                                <td>
                                    @(item.ReturnDate == null
                                        ? "Chưa trả"
                                        : item.ReturnDate.Value.ToString("dd/MM/yyyy"))
                                </td>

                                <td>
                                    @if (item.ReturnDate == null)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Đang mượn
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            Đã trả
                                        </span>
                                    }
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                Không có dữ liệu
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>