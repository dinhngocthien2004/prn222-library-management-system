@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Danh Sách Người Dùng";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h4 class="mb-0 text-center">👥 Danh Sách Người Dùng</h4>
        </div>

        <div class="card-body">

            <p class="text-muted text-center">
                Danh sách các thành viên đã mượn ít nhất 1 cuốn sách
            </p>

            <table class="table table-hover table-bordered align-middle">

                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 70%;">Người Dùng</th>
                        <th style="width: 30%;">Thao Tác</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td class="text-center">
                                    @(item.UserName ?? "N/A")
                                </td>

                                <td class="text-center">
                                    <a asp-controller="Loans"
                                       asp-action="UserLoans"
                                       asp-route-userId="@item.UserId"
                                       class="btn btn-info btn-sm px-3">
                                        Chi Tiết
                                    </a>
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center text-muted">
                                Không có dữ liệu
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- NÚT QUAY VỀ NẰM NGOÀI CARD -->
    <div class="mt-3">
        <a asp-controller="Home"
           asp-action="Index"
           class="btn custom-back-btn">
            ← Quay Lại Trang Chủ
        </a>
    </div>

</div>