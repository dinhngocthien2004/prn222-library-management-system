@model BusinessObjects.Entities.Loan

@{
    ViewData["Title"] = "Delete Loan";
}

<div class="container mt-4">

    <div class="card shadow-lg border-danger">

        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">⚠ Delete Loan</h4>
        </div>

        <div class="card-body">

            <div class="alert alert-danger">
                Are you sure you want to delete this loan record?
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">
                    User
                </div>

                <div class="col-md-8">
                    @Model.User?.Email
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">
                    Copy Barcode
                </div>

                <div class="col-md-8">
                    @Model.Copy?.Barcode
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">
                    Loan Date
                </div>

                <div class="col-md-8">
                    @Model.LoanDate?.ToString("dd/MM/yyyy")
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">
                    Due Date
                </div>

                <div class="col-md-8">
                    @Model.DueDate.ToString("dd/MM/yyyy")
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">
                    Return Date
                </div>

                <div class="col-md-8">
                    @(Model.ReturnDate == null
                                        ? "Not Returned"
                                        : Model.ReturnDate.Value.ToString("dd/MM/yyyy"))
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4 fw-bold">
                    Status
                </div>

                <div class="col-md-8">

                    @if (Model.ReturnDate == null)
                    {
                        <span class="badge bg-warning text-dark">
                            Borrowing
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-success">
                            Returned
                        </span>
                    }

                </div>
            </div>

        </div>

        <div class="card-footer">

            <form asp-action="Delete">

                <input type="hidden" asp-for="LoanId" />

                <button type="submit"
                        class="btn btn-danger"
                        onclick="return confirm('Are you sure you want to delete this loan?')">
                    Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Back to List
                </a>

            </form>

        </div>

    </div>

</div>