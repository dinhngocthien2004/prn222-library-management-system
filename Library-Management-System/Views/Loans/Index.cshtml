@model IEnumerable<BusinessObjects.Entities.Loan>

@{
    ViewData["Title"] = "Loan Management";
}

<div class="container-fluid mt-3">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">📚 Loan Management</h2>

        @if (Context.Session.GetInt32("RoleID") == 1)
        {
            <a asp-action="Create" class="btn btn-primary">
                + Create Loan
        </a>
        }
    </div>

    <div class="card shadow">

        <div class="card-header bg-dark text-white">
            Loan List
        </div>

        <div class="card-body">

            <table class="table table-striped table-hover align-middle">

                <thead class="table-light">
                    <tr>
                        <th>User</th>
                        <th>Copy ID</th>
                        <th>Loan Date</th>
                        <th>Due Date</th>
                        <th>Return Date</th>
                        <th>Status</th>
                        <th width="200">Action</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.User?.Email
                            </td>

                            <td>
                                @item.CopyId
                            </td>

                            <td>
                                @item.LoanDate?.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @item.DueDate.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @(item.ReturnDate == null
                                                            ? "Not Returned"
                                                            : item.ReturnDate.Value.ToString("dd/MM/yyyy"))
                        </td>

                            <td>
                            @if (item.ReturnDate == null)
                                {
                                    <span class="badge bg-warning text-dark">
                                        Borrowing
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Returned
                                    </span>
                                }
                            </td>

                            <td>
                                @if (Context.Session.GetInt32("RoleID") == 1)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.LoanId"
                                    class="btn btn-sm btn-warning">
                                        Edit
                                    </a>

                                    <a asp-action="Details" asp-route-id="@item.LoanId"
                                    class="btn btn-sm btn-info text-white">
                                        Details
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.LoanId"
                                    class="btn btn-sm btn-danger">
                                        Delete
                                    </a>
                                }
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>