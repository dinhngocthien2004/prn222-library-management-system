@model BusinessObjects.Entities.Reader

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-danger text-white text-center">
            <h3>⚠ Xóa độc giả</h3>
        </div>

        <!-- BODY -->
        <div class="card-body text-center p-4">

            <h5 class="mb-3 text-danger">Bạn có chắc muốn xóa độc giả này?</h5>

            <div class="alert alert-warning">
                ⚠ Hành động này không thể hoàn tác!
            </div>

            <!-- THÔNG TIN -->
            <div class="mb-4">
                <p><strong>Mã thẻ:</strong> @Model.CardNumber</p>
                <p><strong>Địa chỉ:</strong> @Model.Address</p>
                <p><strong>Trạng thái:</strong> @Model.Status</p>
            </div>

            <!-- FORM -->
            <form asp-action="Delete">
                <input type="hidden" asp-for="ReaderId" />

                <div class="d-flex justify-content-center gap-3">
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        ⬅ Hủy
                    </a>

                    <button type="submit" class="btn btn-danger px-4">
                        🗑 Xóa
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>