@model BusinessObjects.Entities.Reader

<div class="container mt-5">
    <div class="card shadow-lg rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white text-center">
            <h3>👤 Thêm độc giả</h3>
            <small>Nhập thông tin độc giả mới</small>
        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            <form asp-action="Create">

                <div class="row">

                    <!-- USER -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">User</label>
                        <select asp-for="UserId" asp-items="ViewBag.UserId"
                                class="form-select"></select>
                    </div>

                    <!-- CARD NUMBER -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Card Number</label>
                        <input asp-for="CardNumber" class="form-control" placeholder="Nhập mã thẻ..." />
                    </div>

                    <!-- DATE OF BIRTH -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Date Of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                    </div>

                    <!-- MEMBERSHIP DATE -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Membership Date</label>
                        <input asp-for="MembershipDate" type="date" class="form-control" />
                    </div>

                    <!-- ADDRESS -->
                    <div class="col-12 mb-3">
                        <label class="form-label fw-bold">Address</label>
                        <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ..." />
                    </div>

                    <!-- STATUS -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Status</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Active">✅ Active</option>
                            <option value="Inactive">❌ Inactive</option>
                        </select>
                    </div>

                </div>

                <!-- BUTTON -->
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary">
                        ⬅ Quay lại
                    </a>

                    <button type="submit" class="btn btn-success px-4">
                        💾 Tạo mới
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>