@model BusinessObjects.Entities.Book

@{
    ViewData["Title"] = "Chi Tiết Sách";

    // Lấy RoleID từ Session
    var role = Context.Session.GetInt32("RoleID");
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-info text-white">
            <h4>📘 Chi Tiết Sách</h4>
        </div>

        <div class="card-body">

            <div class="row">

                <!-- Ảnh sách -->
                <div class="col-md-4 text-center">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             class="img-fluid rounded shadow"
                             style="max-height:300px;" />
                    }
                </div>

                <!-- Thông tin sách -->
                <div class="col-md-8">

                    <h2 class="mb-3">@Model.Title</h2>

                    <div class="card mb-2 p-2">
                        <strong>ISBN:</strong> @Model.Isbn
                    </div>

                    <div class="card mb-2 p-2">
                        <strong>Nhà xuất bản:</strong> @Model.Publisher
                    </div>

                    <div class="card mb-2 p-2">
                        <strong>Năm phát hành:</strong> @Model.PublishedYear
                    </div>

                    <div class="card mb-2 p-2">
                        <strong>Ngày thêm:</strong>
                        @(Model.DateAdded != null
                            ? Model.DateAdded.Value.ToString("dd/MM/yyyy HH:mm")
                            : "")
                    </div>

                    <div class="card mb-2 p-2">
                        <strong>Thể loại:</strong>

                        @if (Model.Category != null)
                        {
                            <span class="badge bg-primary">
                                @Model.Category.CategoryName
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                Chưa có thể loại
                            </span>
                        }
                    </div>

                    <div class="card p-2">
                        <strong>Mô tả:</strong>
                        <p class="mt-2">
                            @(string.IsNullOrEmpty(Model.Description)
                                ? "Chưa có mô tả."
                                : Model.Description)
                        </p>
                    </div>

                </div>

            </div>

        </div>

        <!-- Footer -->
        <div class="card-footer text-end">

            <a asp-action="Index" class="btn btn-secondary">
                ← Quay lại
            </a>

            @if (role != 3)
            {
                <a asp-action="Edit"
                   asp-route-id="@Model.BookId"
                   class="btn btn-warning">
                    ✏️ Chỉnh sửa
                </a>
            }

        </div>

    </div>

</div>