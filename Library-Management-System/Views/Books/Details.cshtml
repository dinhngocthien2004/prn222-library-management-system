@model BusinessObjects.Entities.Book

@{
    ViewData["Title"] = "Chi Tiết Sách";

    var role = Context.Session.GetInt32("RoleID");
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-info text-white">
            <h4>📘 Chi Tiết Sách</h4>
        </div>

        <div class="card-body">

            <div class="row">

                <!-- Ảnh sách -->
                <div class="col-md-4 text-center">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             class="img-fluid rounded shadow"
                             style="max-height:300px;" />
                    }
                </div>

                <!-- Thông tin sách -->
                <div class="col-md-8">

                    <h2 class="mb-3">@Model.Title</h2>

                    <div class="card mb-2 p-2 d-flex">
                        <strong style="min-width:150px;">ISBN:</strong>
                        <span>@Model.Isbn</span>
                    </div>

                    <div class="card mb-2 p-2 d-flex">
                        <strong style="min-width:150px;">Nhà xuất bản:</strong>
                        <span>@Model.Publisher</span>
                    </div>

                    <div class="card mb-2 p-2 d-flex">
                        <strong style="min-width:150px;">Năm phát hành:</strong>
                        <span>@Model.PublishedYear</span>
                    </div>

                    <div class="card mb-2 p-2 d-flex">
                        <strong style="min-width:150px;">Ngày thêm:</strong>
                        <span>
                            @(Model.DateAdded != null
                                ? Model.DateAdded.Value.ToString("dd/MM/yyyy HH:mm")
                                : "")
                        </span>
                    </div>

                    <div class="card mb-2 p-2 d-flex">
                        <strong style="min-width:150px;">Thể loại:</strong>

                        @if (Model.Category != null)
                        {
                            <span>@Model.Category.CategoryName</span>
                        }
                        else
                        {
                            <span class="text-muted">Chưa có thể loại</span>
                        }
                    </div>

                    <div class="card mb-2 p-2 d-flex">
                        <strong style="min-width:150px;">Số lượng:</strong>
                        <span class="fw-bold">@Model.BookCopies.Count()</span>
                    </div>

                    <div class="card p-2">
                        <strong>Mô tả:</strong>
                        <p class="mt-2 mb-0">
                            @(string.IsNullOrEmpty(Model.Description)
                                ? "Chưa có mô tả."
                                : Model.Description)
                        </p>
                    </div>

                </div>

            </div>

        </div>

        <!-- Footer -->
        <div class="card-footer d-flex justify-content-end gap-2">

            <a asp-action="Index" class="btn btn-secondary">
                ← Quay lại
            </a>

            @if (role == 3)
            {
                <a asp-action="BorrowConfirm"
                   asp-route-id="@Model.BookId"
                   class="btn btn-success">
                    📚 Mượn Sách
                </a>
            }

            @if (role != 3)
            {
                <a asp-action="Edit"
                   asp-route-id="@Model.BookId"
                   class="btn btn-warning">
                    ✏️ Chỉnh sửa
                </a>
            }

        </div>

    </div>

</div>