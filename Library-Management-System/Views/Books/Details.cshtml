@model BusinessObjects.Entities.Book

@{
    ViewData["Title"] = "Chi Tiết Sách";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0">
        <div class="card-header text-white"
             style="background: linear-gradient(90deg,#17a2b8,#0dcaf0);">
            <h4 class="mb-0">📘 Chi Tiết Sách</h4>
        </div>

        <div class="card-body">
            <div class="row">

                <!-- CỘT ẢNH -->
                <div class="col-md-4 text-center border-end">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             class="img-fluid rounded shadow-sm mb-3"
                             style="max-height: 350px;" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/250x350?text=No+Image"
                             class="img-fluid rounded shadow-sm mb-3" />
                    }
                </div>

                <!-- CỘT THÔNG TIN -->
                <div class="col-md-8">

                    <h3 class="fw-bold mb-3">@Model.Title</h3>

                    <div class="bg-light p-3 rounded shadow-sm">

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>ISBN:</strong> @Model.Isbn
                        </div>

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>Nhà xuất bản:</strong> @Model.Publisher
                        </div>

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>Năm phát hành:</strong> @Model.PublishedYear
                        </div>

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>Ngày thêm:</strong>
                            @(Model.DateAdded?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có ngày")
                        </div>

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>Thể loại:</strong>
                            <span class="badge bg-primary">
                                @(Model.Category?.CategoryName ?? "Chưa có thể loại")
                            </span>
                        </div>

                        <div class="border rounded p-3 bg-white">
                            <strong>Mô tả:</strong>
                            <div class="mt-2 text-muted">
                                @(string.IsNullOrEmpty(Model.Description)
                                    ? "Chưa có mô tả."
                                    : Model.Description)
                            </div>
                        </div>

                    </div>

                </div>
            </div>

            <div class="text-end mt-4">
                <a asp-action="Index" class="btn btn-secondary px-4">
                    ← Quay lại
                </a>

                <a asp-action="Edit"
                   asp-route-id="@Model.BookId"
                   class="btn btn-warning px-4">
                    ✏️ Chỉnh sửa
                </a>
            </div>
        </div>
    </div>

</div>