@model LibraryManagementSystem.DAL.Entities.Book

@{
    ViewData["Title"] = "Details";
}

<h2>Book Details</h2>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <img src="@Model.ImageUrl"
                     class="img-fluid"
                     onerror="this.src='/images/no-image.png'" />
            </div>

            <div class="col-md-8">
                <p><strong>Book Name:</strong> @Model.Title</p>
                <p><strong>ISBN:</strong> @Model.Isbn</p>
                <p><strong>Publisher:</strong> @Model.Publisher</p>
                <p><strong>Publish Year:</strong> @Model.PublishedYear</p>

                <a asp-action="Edit" asp-route-id="@Model.BookId" class="btn btn-warning">Edit</a>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>
        </div>
    </div>
</div>
