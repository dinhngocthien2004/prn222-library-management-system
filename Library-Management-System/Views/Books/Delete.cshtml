@model LibraryManagementSystem.DAL.Entities.Book

@{
    ViewData["Title"] = "Xóa sách";
}

<h2 class="text-danger mb-3">🗑 Xóa sách</h2>

<div class="alert alert-warning">
    <strong>⚠ Cảnh báo:</strong> Bạn đang chuẩn bị xóa sách sau.
    Hành động này <b>không thể hoàn tác</b>.
</div>

<div class="card mb-3 shadow-sm">
    <div class="card-header bg-dark text-white">
        📘 Thông tin sách
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Tiêu đề</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3">Mã định danh</dt>
            <dd class="col-sm-9">@Model.Isbn</dd>

            <dt class="col-sm-3">Nhà xuất bản</dt>
            <dd class="col-sm-9">@Model.Publisher</dd>

            <dt class="col-sm-3">Năm xuất bản</dt>
            <dd class="col-sm-9">@Model.PublishedYear</dd>

            <dt class="col-sm-3">Mô tả</dt>
            <dd class="col-sm-9">@Model.Description</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="BookId" />

    <button type="submit" class="btn btn-danger">
        ❌ Xác nhận xóa
    </button>

    <a asp-action="Index" class="btn btn-secondary ms-2">
        ⬅ Hủy bỏ
    </a>
</form>
