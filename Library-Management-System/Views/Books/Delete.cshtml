@model BusinessObjects.Entities.Book

@{
    ViewData["Title"] = "Xóa Sách";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0">

        <div class="card-header text-white"
             style="background: linear-gradient(90deg,#dc3545,#ff6b6b);">
            <h4 class="mb-0">⚠ Xác Nhận Xóa Sách</h4>
        </div>

        <div class="card-body">

            <div class="alert alert-danger text-center fw-semibold">
                Bạn có chắc chắn muốn xóa cuốn sách này không?
            </div>

            <div class="row">

                <!-- CỘT ẢNH -->
                <div class="col-md-4 text-center border-end">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             class="img-fluid rounded shadow-sm mb-3"
                             style="max-height: 300px;" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/250x350?text=No+Image"
                             class="img-fluid rounded shadow-sm mb-3" />
                    }
                </div>

                <!-- CỘT THÔNG TIN -->
                <div class="col-md-8">

                    <h4 class="fw-bold mb-3 text-danger">@Model.Title</h4>

                    <div class="bg-light p-3 rounded shadow-sm">

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>ISBN:</strong> @Model.Isbn
                        </div>

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>Nhà xuất bản:</strong> @Model.Publisher
                        </div>

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>Năm phát hành:</strong> @Model.PublishedYear
                        </div>

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>Ngày thêm:</strong>
                            @(Model.DateAdded?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có ngày")
                        </div>

                        <div class="border rounded p-2 mb-2 bg-white">
                            <strong>Thể loại:</strong>
                            <span class="badge bg-secondary">
                                @(Model.Category?.CategoryName ?? "Chưa có thể loại")
                            </span>
                        </div>

                    </div>

                </div>
            </div>

            <div class="text-end mt-4">

                <form asp-action="Delete" asp-route-id="@Model.BookId">
              
                    <input type="hidden" asp-for="BookId" />

                    <a asp-action="Index" class="btn btn-secondary px-4 me-2">
                        ← Quay lại
                    </a>

                    <button type="submit" class="btn btn-danger px-4">
                        🗑 Xóa
                    </button>
                </form>

            </div>

        </div>
    </div>

</div>