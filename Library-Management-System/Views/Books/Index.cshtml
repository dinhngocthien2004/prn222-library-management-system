@model IEnumerable<BusinessObjects.Entities.Book>

@{
    ViewData["Title"] = "Danh Sách Sách";

    // Lấy RoleID từ Session
    var role = Context.Session.GetInt32("RoleID");
}

<div class="container mt-4">

    <!-- Tiêu đề + nút thêm -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">📚 Danh Sách Sách</h2>

        @if (role != 3)
        {
            <a asp-action="Create" class="btn btn-success">
                ➕ Thêm Sách Mới
            </a>
        }
    </div>

    <!-- Card bao ngoài -->
    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered table-striped align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>ISBN</th>
                        <th>Publisher</th>
                        <th>Published Year</th>
                        <th>Mô tả</th>
                        <th>Ảnh</th>
                        <th>Ngày thêm</th>
                        <th>Thể loại</th>
                        <th style="width:200px;">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Isbn</td>
                            <td>@item.Publisher</td>
                            <td>@item.PublishedYear</td>

                            <td class="text-start">
                                @(item.Description?.Length > 40
                                    ? item.Description.Substring(0, 40) + "..."
                                    : item.Description)
                            </td>

                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl"
                                         style="height:60px; width:50px; object-fit:cover;" />
                                }
                            </td>

                            <td>
                                @(item.DateAdded != null
                                    ? item.DateAdded.Value.ToString("dd/MM/yyyy")
                                    : "")
                            </td>

                            <td>@item.Category?.CategoryName</td>

                            <td>

                                @if (role != 3)
                                {
                                    <a asp-action="Edit"
                                       asp-route-id="@item.BookId"
                                       class="btn btn-sm btn-warning me-1">
                                        Edit
                                    </a>
                                }

                                <a asp-action="Details"
                                   asp-route-id="@item.BookId"
                                   class="btn btn-sm btn-info me-1">
                                    Details
                                </a>

                                @if (role != 3)
                                {
                                    <a asp-action="Delete"
                                       asp-route-id="@item.BookId"
                                       class="btn btn-sm btn-danger">
                                        Delete
                                    </a>
                                }

                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>