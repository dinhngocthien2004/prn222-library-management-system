@model IEnumerable<LibraryManagementSystem.DAL.Entities.Book>

@{
    ViewData["Title"] = "Quản lý sách";
}

<h2 class="mb-3">📚 Quản lý sách</h2>

<form method="get" class="row mb-3">
    <div class="col-md-8">
        <input type="text" name="keyword" class="form-control"
               placeholder="Nhập tên sách cần tìm..." />
    </div>
    <div class="col-md-4">
        <button type="submit" class="btn btn-primary">🔍 Tìm kiếm</button>
        <a asp-action="Create" class="btn btn-success ms-2">➕ Thêm sách</a>
    </div>
</form>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Tiêu đề</th>
            <th>Mã định danh</th>
            <th>Nhà xuất bản</th>
            <th>Năm xuất bản</th>
            <th style="width: 260px;">Chức năng</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Isbn</td>
                <td>@item.Publisher</td>
                <td>@item.PublishedYear</td>
                <td>
                    <div class="d-flex gap-1">
                        <a asp-action="Details" asp-route-id="@item.BookId"
                           class="btn btn-outline-info btn-sm">
                            👁 Xem
                        </a>

                        <a asp-action="Edit" asp-route-id="@item.BookId"
                           class="btn btn-outline-warning btn-sm">
                            ✏ Sửa
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.BookId"
                           class="btn btn-outline-danger btn-sm">
                            🗑 Xóa
                        </a>
                    </div>
                </td>

            </tr>
        }
    </tbody>
</table>
