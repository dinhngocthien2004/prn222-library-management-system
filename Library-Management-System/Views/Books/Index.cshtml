@model IEnumerable<BusinessObjects.Entities.Book>

@{
    ViewData["Title"] = "Danh Sách Sách";
    var role = Context.Session.GetInt32("RoleID");
}

<div class="container mt-4">

    <!-- Tiêu đề + nút thêm -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">📚 Danh Sách Sách</h2>

        @if (role != 3)
        {
            <a asp-action="Create" class="btn btn-success">
                ➕ Thêm Sách Mới
            </a>
        }
    </div>

    <!-- FILTER -->
    <div class="card shadow-sm mb-3">
        <div class="card-body">

            <form method="get" class="row g-2">

                <div class="col-md-4">
                    <input type="text"
                           name="keyword"
                           class="form-control"
                           placeholder="Tìm theo tên sách hoặc ISBN..."
                           value="@ViewBag.Keyword" />
                </div>

                <div class="col-md-2">
                    <input type="number"
                           name="year"
                           class="form-control"
                           placeholder="Năm"
                           value="@ViewBag.Year" />
                </div>

                <div class="col-md-3">
                    <select name="categoryId"
                            class="form-select"
                            asp-items="ViewBag.Categories">
                        <option value="">Tất cả thể loại</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <button class="btn btn-primary w-100">
                        🔎 Lọc
                    </button>
                </div>

            </form>

        </div>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered table-striped align-middle text-center">

                <thead class="table-dark text-center">
                    <tr>
                        <th>Tên Sách</th>
                        <th>ISBN</th>
                        <th>Tác Giả</th>
                        <th>Năm Xuất Bản</th>
                        <th>Thể Loại</th>
                        <th>Mô Tả</th>
                        <th>Ảnh</th>
                        <th>Ngày Thêm</th>
                        <th style="width:200px;">Thao Tác</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td class="text-start">@item.Title</td>

                            <td>@item.Isbn</td>

                            <td>@item.Publisher</td>

                            <td>@item.PublishedYear</td>

                            <td>
                                @(item.Category != null ? item.Category.CategoryName : "")
                            </td>

                            <td class="text-start">
                                @(item.Description != null && item.Description.Length > 40
                                    ? item.Description.Substring(0, 40) + "..."
                                    : item.Description)
                            </td>

                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl"
                                         style="height:60px; width:50px; object-fit:cover;" />
                                }
                            </td>

                            <td>
                                @(item.DateAdded != null
                                    ? item.DateAdded.Value.ToString("dd/MM/yyyy")
                                    : "")
                            </td>

                            <td>

                                @if (role != 3)
                                {
                                    <a asp-action="Edit"
                                       asp-route-id="@item.BookId"
                                       class="btn btn-sm btn-warning me-1">
                                        Sửa
                                    </a>
                                }

                                <a asp-action="Details"
                                   asp-route-id="@item.BookId"
                                   class="btn btn-sm btn-info me-1">
                                    Xem
                                </a>

                                @if (role != 3)
                                {
                                    <a asp-action="Delete"
                                       asp-route-id="@item.BookId"
                                       class="btn btn-sm btn-danger">
                                        Xóa
                                    </a>
                                }

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

            <!-- PAGINATION + BACK BUTTON -->
            <div class="position-relative mt-3">

                <!-- Nút quay lại (bên trái) -->
                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-secondary position-absolute start-0">
                    ← Quay Lại Trang Chủ
                </a>

                <!-- Phân trang (ở giữa) -->
                <div class="text-center">

                    @if (ViewBag.TotalPages > 1)
                    {

                        @if (ViewBag.CurrentPage > 1)
                        {
                            <a class="btn btn-outline-primary me-1"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage - 1)"
                               asp-route-keyword="@ViewBag.Keyword"
                               asp-route-year="@ViewBag.Year"
                               asp-route-categoryId="@ViewBag.CategoryId">
                                Trước
                            </a>
                        }

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            if (i == ViewBag.CurrentPage)
                            {
                                <span class="btn btn-primary me-1">@i</span>
                            }
                            else
                            {
                                <a class="btn btn-outline-primary me-1"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-keyword="@ViewBag.Keyword"
                                   asp-route-year="@ViewBag.Year"
                                   asp-route-categoryId="@ViewBag.CategoryId">
                                    @i
                                </a>
                            }
                        }

                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <a class="btn btn-outline-primary ms-1"
                               asp-action="Index"
                               asp-route-page="@(ViewBag.CurrentPage + 1)"
                               asp-route-keyword="@ViewBag.Keyword"
                               asp-route-year="@ViewBag.Year"
                               asp-route-categoryId="@ViewBag.CategoryId">
                                Sau
                            </a>
                        }

                    }

                </div>

            </div>

        </div>
    </div>

</div>