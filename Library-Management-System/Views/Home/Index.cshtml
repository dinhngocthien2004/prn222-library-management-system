@{
    ViewData["Title"] = "Home Page";
}

<!-- HERO -->

<div class="hero-section text-center text-white">
    <div class="container">
        <h1 class="display-4 fw-bold">📚 Hệ thống Quản lý Thư viện</h1>
        <p class="lead">Quản lý sách, độc giả và quy trình mượn trả hiệu quả</p>

        <!-- SEARCH -->
        <form asp-controller="Books" asp-action="Index" method="get" class="search-box mt-4">

            <input class="form-control search-input"
                   type="search"
                   name="keyword"
                   placeholder="Tìm sách theo tên, ISBN..."
                   value="@Context.Request.Query["keyword"]">

            <button class="btn btn-light search-btn">
                🔍 Tìm kiếm
            </button>

        </form>
    </div>

</div>

<div class="container mt-5">

    <!-- MAIN FEATURES -->
    <div class="row g-4">

        <!-- BOOKS -->
        <div class="col-md-4">
            <div class="card dashboard-card text-center h-100">
                <div class="card-body">
                    <div class="icon">📚</div>

                    <h5 class="mt-3">Quản lý Sách</h5>

                    <p class="text-muted">
                        Thêm, sửa và quản lý toàn bộ kho sách.
                    </p>

                    <a asp-controller="Books"
                       asp-action="Index"
                       class="btn btn-primary w-100">
                        Xem Kho Sách
                    </a>
                </div>
            </div>
        </div>


        <!-- READERS -->
        <div class="col-md-4">
            <div class="card dashboard-card text-center h-100">
                <div class="card-body">

                    <div class="icon">👥</div>

                    <h5 class="mt-3">Độc giả</h5>

                    <p class="text-muted">
                        Quản lý thông tin thành viên thư viện.
                    </p>

                    <a href="#" class="btn btn-primary w-100">
                        Danh sách độc giả
                    </a>

                </div>
            </div>
        </div>


        <!-- LOANS -->
        <div class="col-md-4">
            <div class="card dashboard-card text-center h-100">
                <div class="card-body">

                    <div class="icon">🔄</div>

                    <h5 class="mt-3">Mượn & Trả</h5>

                    <p class="text-muted">
                        Tạo phiếu mượn và xử lý trả sách.
                    </p>

                    <a asp-controller="Loans"
                       asp-action="Index"
                       class="btn btn-primary w-100">
                        Tạo Phiếu Mượn
                    </a>

                </div>
            </div>
        </div>

    </div>


    <!-- STATISTICS -->
    <div class="row mt-5 text-center">

        <h3 class="mb-4">📊 Thống kê hệ thống</h3>

        <div class="col-md-3 col-6">
            <div class="stat-box">
                <h2 class="text-primary">1250</h2>
                <p>Tổng đầu sách</p>
            </div>
        </div>

        <div class="col-md-3 col-6">
            <div class="stat-box">
                <h2 class="text-success">45</h2>
                <p>Đang mượn</p>
            </div>
        </div>

        <div class="col-md-3 col-6">
            <div class="stat-box">
                <h2 class="text-warning">12</h2>
                <p>Quá hạn</p>
            </div>
        </div>

        <div class="col-md-3 col-6">
            <div class="stat-box">
                <h2 class="text-info">300</h2>
                <p>Thành viên</p>
            </div>
        </div>

    </div>


    <!-- CHART -->
    <div class="card mt-5 shadow-sm">
        <div class="card-body">

            <h4 class="text-center mb-4">Biểu đồ thống kê</h4>

            <canvas id="libraryChart"></canvas>

        </div>
    </div>

</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        const ctx = document.getElementById('libraryChart');

        new Chart(ctx, {

            type: 'bar',

            data: {

                labels: ['Tổng sách', 'Đang mượn', 'Quá hạn', 'Thành viên'],

                datasets: [{
                    data: [1250,45,12,300],

                    backgroundColor: [
                        '#0d6efd',
                        '#198754',
                        '#ffc107',
                        '#0dcaf0'
                    ],

                    borderRadius:8
                }]

            },

            options:{
                plugins:{
                    legend:{display:false}
                }
            }

        });

    </script>

}
