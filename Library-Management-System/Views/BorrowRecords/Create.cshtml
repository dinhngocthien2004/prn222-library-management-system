@using BusinessObjects.Entities
@model BorrowRecord

@{
    ViewData["Title"] = "Mượn sách";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- HEADER -->
                <div class="bg-gradient p-4 text-white text-center"
                     style="background: linear-gradient(135deg, #4e73df, #224abe);">
                    <h3 class="mb-1">📖 Mượn sách</h3>
                    <small class="opacity-75">Tạo phiếu mượn sách nhanh chóng</small>
                </div>

                <!-- BODY -->
                <div class="card-body p-4">

                    <form method="post">

                        <!-- CHỌN SÁCH -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                📚 Chọn sách
                            </label>

                            <select asp-for="BookId"
                                    asp-items="ViewBag.BookId"
                                    class="form-select shadow-sm">
                                <option value="">-- Chọn sách --</option>
                            </select>

                            <span asp-validation-for="BookId"
                                  class="text-danger small"></span>
                        </div>

                        <!-- NGÀY HẾT HẠN -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                📅 Ngày hết hạn
                            </label>

                            <input asp-for="DueDate"
                                   type="date"
                                   class="form-control shadow-sm" />

                            <span asp-validation-for="DueDate"
                                  class="text-danger small"></span>
                        </div>

                        <!-- BUTTON -->
                        <div class="d-flex justify-content-between align-items-center mt-4">

                            <a asp-action="Index"
                               class="btn btn-outline-secondary px-4">
                                ⬅ Quay lại
                            </a>

                            <button type="submit"
                                    class="btn btn-primary px-4 shadow-sm">
                                📌 Tạo phiếu
                            </button>

                        </div>

                    </form>

                </div>

                <!-- FOOTER -->
                <div class="text-center py-2 small text-muted">
                    📌 Vui lòng kiểm tra thông tin trước khi tạo
                </div>

            </div>
        </div>
    </div>
</div>