@model IEnumerable<BusinessObjects.Entities.User>

@{
    var roleId = Context.Session.GetInt32("RoleID");
}

<div class="card shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>👤 Quản lý người dùng</h2>
        @if (roleId == 1) // Admin mới thấy nút thêm
        {
            <a href="/Users/Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Thêm User
            </a>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Email</th>
                    <th>Họ tên</th>
                    <th>Role</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    if (u.UserRoles != null && u.UserRoles.Any(r => r.Role.RoleName == "Admin"))
                    {
                        continue;
                    }

                    <tr>
                        <td>@u.Email</td>
                        <td>@u.FullName</td>
                        <td>
                            @if (u.Role != null)
                            {
                                var badgeClass = u.Role.RoleName switch
                                {
                                    "Admin" => "bg-danger",
                                    "Moderator" => "bg-warning text-dark",
                                    _ => "bg-info"
                                };
                                <span class="badge @badgeClass">@u.Role.RoleName</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Chưa phân quyền</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (roleId == 1)
                            {
                                <a asp-action="DeleteUser" asp-route-id="@u.UserId"
                                   class="btn btn-sm btn-outline-danger"
                                   data-bs-toggle="tooltip"
                                   title="Xóa người dùng này">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}